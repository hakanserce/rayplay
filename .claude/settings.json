{
  "permissions": {
    "deny": [
      "Write(*.env)",
      "Write(.env.*)",
      "Write(*.key)",
      "Write(*.pem)",
      "Write(*.secret)",
      "Edit(*.env)",
      "Edit(.env.*)",
      "Edit(*.key)",
      "Edit(*.pem)",
      "Edit(.git/*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '"[\(.timestamp // now | todate)] \(.tool_name // "unknown") \(.tool_input.command // .tool_input.file_path // "")"' >> .claude/audit.log",
            "async": true
          }
        ]
      }
    ]
  }
}
