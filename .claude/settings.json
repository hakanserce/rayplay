{
  "permissions": {
    "allow": [
      "Bash(cargo fmt *)",
      "Bash(cargo test *)",
      "Bash(cargo clippy *)",
      "Bash(cargo make *)",
      "Bash(cargo build *)",
      "Bash(cargo check *)",
      "Bash(cargo llvm-cov *)",
      "Bash(cargo bench *)",
      "Bash(cargo run *)",
      "Bash(cargo clean *)",
      "Bash(cargo search *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(gh run *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git rebase *)",
      "Bash(git checkout *)",
      "Bash(git worktree *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(cargo add *)",
      "Bash(cargo remove *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(echo *)",
      "Bash(sort *)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(git merge-base *)",
      "Bash(git shortlog *)",
      "Read(/tmp/*)",
      "Write(/tmp/*)"
    ],
    "deny": [
      "Write(*.env)",
      "Write(.env.*)",
      "Write(*.key)",
      "Write(*.pem)",
      "Write(*.secret)",
      "Edit(*.env)",
      "Edit(.env.*)",
      "Edit(*.key)",
      "Edit(*.pem)",
      "Edit(.git/*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[\\(.timestamp // (now | todate))] \\(.tool_name // \"unknown\") \\(.tool_input.command // .tool_input.file_path // \"\")\"' >> .claude/audit.log",
            "async": true
          }
        ]
      }
    ]
  }
}
