#!/usr/bin/env bash
# Pre-commit hook: block commits with unformatted Rust code.
# Install: git config core.hooksPath .githooks

set -e

if ! cargo fmt --all -- --check 2>/dev/null; then
    echo ""
    echo "ERROR: Rust formatting check failed."
    echo "Run 'cargo fmt --all' to fix, then re-commit."
    echo ""
    exit 1
fi
